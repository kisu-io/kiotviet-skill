{
  "jobs": [
    {
      "id": "daily-kiotviet-sales",
      "agentId": "universal-team",
      "name": "daily-kiotviet-sales",
      "enabled": false,
      "schedule": {
        "expr": "0 8 * * *",
        "kind": "cron"
      },
      "sessionTarget": "isolated",
      "wakeMode": "now",
      "payload": {
        "kind": "agentTurn",
        "message": "Run the kiotviet skill to get today's sales report and top 5 products. Format as a clear daily business summary in Vietnamese. Include total revenue, number of invoices, and top sellers."
      },
      "delivery": {
        "mode": "announce",
        "channel": "discord"
      }
    },
    {
      "id": "daily-kiotviet-inventory",
      "agentId": "universal-team",
      "name": "daily-kiotviet-inventory",
      "enabled": false,
      "schedule": {
        "expr": "0 9 * * *",
        "kind": "cron"
      },
      "sessionTarget": "isolated",
      "wakeMode": "now",
      "payload": {
        "kind": "agentTurn",
        "message": "Check KiotViet inventory for products with stock below 10 units. If any found, post an alert with product names, current stock, and suggested reorder quantities."
      },
      "delivery": {
        "mode": "announce",
        "channel": "discord"
      }
    },
    {
      "id": "weekly-kiotviet-report",
      "agentId": "universal-team",
      "name": "weekly-kiotviet-report",
      "enabled": false,
      "schedule": {
        "expr": "0 9 * * 1",
        "kind": "cron"
      },
      "sessionTarget": "isolated",
      "wakeMode": "now",
      "payload": {
        "kind": "agentTurn",
        "message": "Generate a weekly KiotViet business summary: revenue vs last week, top 10 products, new customers acquired, pending/overdue invoices. Present as an executive summary."
      },
      "delivery": {
        "mode": "announce",
        "channel": "discord"
      }
    }
  ]
}
