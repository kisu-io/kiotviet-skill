{
  "jobs": [
    {
      "id": "daily-sales",
      "name": "daily-sales",
      "enabled": false,
      "schedule": "0 8 * * *",
      "script": "scripts/get_sales_report.js",
      "description": "Daily sales report + top 5 products"
    },
    {
      "id": "daily-inventory",
      "name": "daily-inventory",
      "enabled": false,
      "schedule": "0 9 * * *",
      "script": "scripts/get_low_stock.js",
      "args": "--threshold=10",
      "description": "Low stock alert for products below 10 units"
    },
    {
      "id": "weekly-report",
      "name": "weekly-report",
      "enabled": false,
      "schedule": "0 9 * * 1",
      "script": "scripts/get_sales_report.js",
      "description": "Weekly executive business summary"
    }
  ]
}
